{
  "manifest_version": 3,
  "name": "Authentic",
  "version": "0.2.0",
  "description": "Block AI-generated content on Pinterest using real visual detection.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Authentic"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.pinterest.com/*", "*://*.pinterest.fr/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "permissions": ["storage"],
  "host_permissions": [
    "*://*.pinterest.com/*",
    "*://*.pinterest.fr/*",
    "https://api.sightengine.com/*"
  ]
}
